{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",   // (Descomentei para organizar melhor)
    "outDir": "./dist",   // (Descomentei para organizar melhor)

    // Environment Settings
    "module": "commonjs",
    "target": "es2016",
    "esModuleInterop": true, // <-- ADICIONADO: Permite importar o Express sem erros!

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false, // <-- ALTERADO PARA FALSE: Resolve o erro principal!
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*"] // <-- ADICIONADO: Diz ao TS para compilar apenas a pasta src
}